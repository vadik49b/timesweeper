{
  "name": "timesweeper",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:api": "wrangler dev -c worker/wrangler.toml --env dev",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "format": "prettier --write src/ && prettier --write worker/src",
    "deploy:api": "wrangler deploy -c worker/wrangler.toml",
    "deploy:fe": "npm run build && wrangler pages deploy dist --project-name timesweeper",
    "deploy:all": "npm run deploy:api && npm run deploy:fe"
  },
  "dependencies": {
    "idb": "^8.0.3",
    "solid-js": "^1.9.10"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "prettier": "^3.8.1",
    "typescript": "~5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-solid": "^2.11.10",
    "wrangler": "^4.33.1"
  }
}
